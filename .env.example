# Backend AI providers
# Optional for local demos. If no provider key is configured, NexusData uses
# deterministic rule-based insights.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional Supabase persistence
# If empty, the backend stores analyses in backend/storage/analyses.json.
SUPABASE_URL=
SUPABASE_KEY=

# Application
APP_ENV=development
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
