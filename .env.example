# Configuración de Gemini API (GRATIS)
# =====================================
# 
# Para obtener tu API key gratuita:
# 1. Visita: https://ai.google.dev/
# 2. Haz clic en "Get API key in Google AI Studio"
# 3. Inicia sesión con tu cuenta de Google
# 4. Crea una nueva API key (es gratis, 1,500 requests/minuto)
# 5. Copia la key y pégala aquí
#
# NOTA: Estamos usando gemini-1.5-flash que es:
# - Totalmente gratuito
# - Límites generosos: 1,500 requests/minuto, 1 millón tokens/minuto
# - Perfecto para generar insights y recomendaciones de gráficos

GEMINI_API_KEY=tu_api_key_aqui

# El backend automáticamente usará gemini-1.5-flash cuando detecte esta variable
